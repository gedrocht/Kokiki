PROJECT_NAME           = "Kokiki Payroll Platform"
PROJECT_BRIEF          = "Cross-language payroll system with COBOL and Spring Boot."
OUTPUT_DIRECTORY       = build/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OPTIMIZE_OUTPUT_JAVA   = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
INPUT                  = spring-control-client/src/main/java \
                         cobol-core/src/main/cobol \
                         README.md \
                         docs
FILE_PATTERNS          = *.java *.cbl *.md
RECURSIVE              = YES
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
